# Chrome Extension — build-time env vars
# These are injected by apps/extension/scripts/build.mjs from the root .env.local
# The extension build script reads NEXT_PUBLIC_* variables automatically.
# No separate .env file is needed for the extension — just populate the root .env.local.

# Web app URL that the extension "Open web app" button links to:
# NEXT_PUBLIC_EXTENSION_IMPORT_URL=https://your-web-app.com
